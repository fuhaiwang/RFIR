ninja_required_version = 1.3
cxx = c++
nvcc = /opt/anaconda3/envs/wfh_3dgsrf1/bin/nvcc

cflags = -pthread -B /opt/anaconda3/envs/wfh_3dgsrf1/compiler_compat -Wl,--sysroot=/ -Wsign-compare -DNDEBUG -g -fwrapv -O3 -Wall -Wstrict-prototypes -fPIC -I/opt/anaconda3/envs/wfh_3dgsrf1/lib/python3.8/site-packages/torch/include -I/opt/anaconda3/envs/wfh_3dgsrf1/lib/python3.8/site-packages/torch/include/torch/csrc/api/include -I/opt/anaconda3/envs/wfh_3dgsrf1/lib/python3.8/site-packages/torch/include/TH -I/opt/anaconda3/envs/wfh_3dgsrf1/lib/python3.8/site-packages/torch/include/THC -I/opt/anaconda3/envs/wfh_3dgsrf1/include -I/opt/anaconda3/envs/wfh_3dgsrf1/include/python3.8 -c
post_cflags = -O3 -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=_C -D_GLIBCXX_USE_CXX11_ABI=0 -std=c++17
cuda_cflags = -I/opt/anaconda3/envs/wfh_3dgsrf1/lib/python3.8/site-packages/torch/include -I/opt/anaconda3/envs/wfh_3dgsrf1/lib/python3.8/site-packages/torch/include/torch/csrc/api/include -I/opt/anaconda3/envs/wfh_3dgsrf1/lib/python3.8/site-packages/torch/include/TH -I/opt/anaconda3/envs/wfh_3dgsrf1/lib/python3.8/site-packages/torch/include/THC -I/opt/anaconda3/envs/wfh_3dgsrf1/include -I/opt/anaconda3/envs/wfh_3dgsrf1/include/python3.8 -c
cuda_post_cflags = -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr --compiler-options ''"'"'-fPIC'"'"'' -I/home/wfh/Projection/Resignalable_3DGS/r3dg-rasterization/third_party/glm/ -O3 -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=_C -D_GLIBCXX_USE_CXX11_ABI=0 -gencode=arch=compute_86,code=compute_86 -gencode=arch=compute_86,code=sm_86 -std=c++17
cuda_dlink_post_cflags = 
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc  $cuda_cflags -c $in -o $out $cuda_post_cflags





build /home/wfh/Projection/Resignalable_3DGS/r3dg-rasterization/build/temp.linux-x86_64-cpython-38/cuda_rasterizer/backward.o: cuda_compile /home/wfh/Projection/Resignalable_3DGS/r3dg-rasterization/cuda_rasterizer/backward.cu
build /home/wfh/Projection/Resignalable_3DGS/r3dg-rasterization/build/temp.linux-x86_64-cpython-38/cuda_rasterizer/forward.o: cuda_compile /home/wfh/Projection/Resignalable_3DGS/r3dg-rasterization/cuda_rasterizer/forward.cu
build /home/wfh/Projection/Resignalable_3DGS/r3dg-rasterization/build/temp.linux-x86_64-cpython-38/cuda_rasterizer/rasterizer_impl.o: cuda_compile /home/wfh/Projection/Resignalable_3DGS/r3dg-rasterization/cuda_rasterizer/rasterizer_impl.cu
build /home/wfh/Projection/Resignalable_3DGS/r3dg-rasterization/build/temp.linux-x86_64-cpython-38/ext.o: compile /home/wfh/Projection/Resignalable_3DGS/r3dg-rasterization/ext.cpp
build /home/wfh/Projection/Resignalable_3DGS/r3dg-rasterization/build/temp.linux-x86_64-cpython-38/rasterize_points.o: cuda_compile /home/wfh/Projection/Resignalable_3DGS/r3dg-rasterization/rasterize_points.cu






